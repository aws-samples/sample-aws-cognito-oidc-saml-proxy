.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Frontend (for Plan 2)
frontend/node_modules/
frontend/dist/
frontend/src/api/schema.d.ts

# Deploy rollback artifacts (previous Lambda image digests + Cognito user

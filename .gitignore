# Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfplan
infra/tfplan
infra/.terraform.lock.hcl
infra/env/*.auto.tfvars

# Terraform state anywhere in the repo (incl. nested examples) — may contain
# secrets; never commit. Patterns without a leading path are matched repo-wide.
# 'tfplan*' also catches extension-less plan archives (e.g. tfplan-csp).
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan*

# Environment-specific Terraform inputs / backend config (contain account IDs,
# domains, emails). Commit only the *.example templates.
infra/env/*.tfvars
infra/env/*.backend.hcl
!infra/env/*.example


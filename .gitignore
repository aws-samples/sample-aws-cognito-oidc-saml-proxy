frontend/.env.local
frontend/.env.*.local

# Local security-scan outputs (share with Guardian; do not commit)
scan-results/
# ASH (Automated Security Helper) output — CI regenerates this as a job
# artifact; never commit the local scan tree.
.ash/

# MkDocs build output
site/

# Local development config for `npm run dev`.
# In a deployed environment these values are served at runtime from /config.json
# by the Go Lambda (populated from Terraform), so you do NOT rebuild to change them.
# Copy this file to .env.local for local development.

VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Optional: used only by the Config page to show how to wire this app into the
# Federation Gateway as a custom login page.
VITE_GATEWAY_BASE_URL=https://gateway.example.com
VITE_GATEWAY_TENANT=demo

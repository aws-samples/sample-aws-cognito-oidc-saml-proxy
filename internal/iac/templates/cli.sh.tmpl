#!/usr/bin/env bash
# Identity Gateway setup for tenant {{ .TenantSlug }}
# Generated by the onboarding wizard. Run from a shell with admin credentials.

set -euo pipefail

TENANT_SLUG="{{ .TenantSlug }}"
# The ExternalId is the cross-account assume-role shared secret. It is delivered
# out-of-band by the onboarding API (response body) over TLS and must NOT be baked
# into this published artifact — supply it at runtime via the environment.
EXTERNAL_ID="${EXTERNAL_ID:?EXTERNAL_ID must be set in the environment (copy it from the onboarding wizard, delivered over TLS); refusing to run without the assume-role secret}"
SAAS_ACCOUNT_ID="{{ .SaaSAccountID }}"
SAAS_PRINCIPAL_NAME="{{ .SaaSPrincipalName }}"
REGION="${AWS_REGION:-{{ .Region }}}"
# Least-privilege: cognito-idp permissions are scoped to this tenant's user pool.
# Supply the pool id at runtime; never widen the policy Resource to "*".
USER_POOL_ID="${USER_POOL_ID:?USER_POOL_ID must be set (the tenant Cognito user pool id, e.g. eu-north-1_AbC123); refusing to grant cognito-idp on all pools}"
ACCOUNT_ID=$(aws sts get-caller-identity --query 'Account' --output text)
COGNITO_POOL_ARN="arn:aws:cognito-idp:${REGION}:${ACCOUNT_ID}:userpool/${USER_POOL_ID}"

echo "Creating KMS key..."
KMS_KEY_ARN=$(aws kms create-key \
  --description "Identity Gateway tenant ${TENANT_SLUG}" \
  --key-usage ENCRYPT_DECRYPT \
  --region "${REGION}" \
  --query 'KeyMetadata.Arn' --output text)
echo "KMS_KEY_ARN=${KMS_KEY_ARN}"

echo "Creating Secrets Manager secret..."
SECRET_ARN=$(aws secretsmanager create-secret \
  --name "identity-gateway-${REGION}-${TENANT_SLUG}-cognito-secret" \
  --description "Cognito app client secret consumed by Identity Gateway" \
  --kms-key-id "${KMS_KEY_ARN}" \
  --tags "Key=IdentityGatewayTenant,Value=${TENANT_SLUG}" \
  --region "${REGION}" \
  --query 'ARN' --output text)
echo "SECRET_ARN=${SECRET_ARN}"

echo "Creating IAM role..."
TRUST_POLICY=$(cat <<EOF
{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Principal": {"AWS": "arn:aws:iam::${SAAS_ACCOUNT_ID}:role/${SAAS_PRINCIPAL_NAME}"},
    "Action": "sts:AssumeRole",
    "Condition": {"StringEquals": {"sts:ExternalId": "${EXTERNAL_ID}"}}
  }]
}
EOF
)
ROLE_ARN=$(aws iam create-role \
  --role-name "identity-gateway-${TENANT_SLUG}" \
  --assume-role-policy-document "${TRUST_POLICY}" \
  --tags "Key=IdentityGatewayTenant,Value=${TENANT_SLUG}" \
  --query 'Role.Arn' --output text)
echo "ROLE_ARN=${ROLE_ARN}"

echo "Attaching core policy..."
aws iam put-role-policy \
  --role-name "identity-gateway-${TENANT_SLUG}" \
  --policy-name "identity-gateway-core" \
  --policy-document "$(cat <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {"Effect": "Allow", "Action": ["cognito-idp:DescribeUserPool","cognito-idp:DescribeUserPoolClient","cognito-idp:DescribeUserPoolDomain","cognito-idp:ListIdentityProviders"], "Resource": "${COGNITO_POOL_ARN}"},
    {"Effect": "Allow", "Action": "secretsmanager:GetSecretValue", "Resource": "${SECRET_ARN}"},
    {"Effect": "Allow", "Action": ["kms:Decrypt","kms:DescribeKey","kms:GenerateDataKey"], "Resource": "${KMS_KEY_ARN}"},
    {"Effect": "Allow", "Action": "iam:SimulatePrincipalPolicy", "Resource": "${ROLE_ARN}"}
  ]
}
EOF
)"
{{ if .WantUserDirectory }}
echo "Attaching user-directory policy..."
aws iam put-role-policy \
  --role-name "identity-gateway-${TENANT_SLUG}" \
  --policy-name "identity-gateway-user-directory" \
  --policy-document "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"cognito-idp:ListUsers\",\"cognito-idp:AdminGetUser\",\"cognito-idp:ListGroups\",\"cognito-idp:ListUsersInGroup\",\"cognito-idp:AdminListGroupsForUser\"],\"Resource\":\"${COGNITO_POOL_ARN}\"}]}"
{{ end }}
{{ if .WantUserLifecycle }}
echo "Attaching user-lifecycle policy..."
aws iam put-role-policy \
  --role-name "identity-gateway-${TENANT_SLUG}" \
  --policy-name "identity-gateway-user-lifecycle" \
  --policy-document "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Effect\":\"Allow\",\"Action\":[\"cognito-idp:AdminCreateUser\",\"cognito-idp:AdminDisableUser\",\"cognito-idp:AdminEnableUser\",\"cognito-idp:AdminAddUserToGroup\",\"cognito-idp:AdminRemoveUserFromGroup\",\"cognito-idp:AdminResetUserPassword\",\"cognito-idp:CreateGroup\"],\"Resource\":\"${COGNITO_POOL_ARN}\"}]}"
{{ end }}

echo
echo "=== Paste these into the onboarding wizard (Step 4) ==="
echo "Role ARN:   ${ROLE_ARN}"
echo "Secret ARN: ${SECRET_ARN}"

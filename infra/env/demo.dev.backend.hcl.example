# Backend config for the DEMO stack (infra/demo).
#
# Copy to demo.dev.backend.hcl (gitignored) and set your own values, then:
#   cd infra/demo
#   terraform init -backend-config=../env/demo.dev.backend.hcl
#
# The state bucket must be created beforehand and be:
#   - versioned
#   - encrypted with SSE-KMS (set kms_key_id below to your CMK)
#   - public-access-blocked (account-level Block Public Access on)
#
# The demo stack reads the registry and gateway stacks' outputs via
# terraform_remote_state; pass the same bucket name as -var 'state_bucket=...'
# (or in dev.tfvars) so those reads resolve to
# "<env>/registry/terraform.tfstate" and "<env>/gateway/terraform.tfstate".
bucket = "terraform-state-<YOUR_AWS_ACCOUNT_ID>"
key    = "dev/demo/terraform.tfstate"
region = "eu-north-1"

encrypt = true
# SSE-KMS CMK for state-at-rest encryption (omit for SSE-S3/AES256).
kms_key_id = "arn:aws:kms:eu-north-1:<YOUR_AWS_ACCOUNT_ID>:key/<STATE_CMK_KEY_ID>"

# Native S3 state locking (Terraform >= 1.10) — no DynamoDB lock table needed.
use_lockfile = true

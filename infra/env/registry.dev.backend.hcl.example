# Backend config for the REGISTRY stack (infra/registry).
#
# Copy to registry.dev.backend.hcl (gitignored) and set your own values, then:
#   cd infra/registry
#   terraform init -backend-config=../env/registry.dev.backend.hcl
#
# The state bucket must be created beforehand and be:
#   - versioned
#   - encrypted with SSE-KMS (set kms_key_id below to your CMK)
#   - public-access-blocked (account-level Block Public Access on)
#
# The `key` must match the terraform_remote_state config that the gateway/demo
# stacks use to read this stack's outputs: "<env>/registry/terraform.tfstate".
# Pass the same bucket name to the stacks as -var 'state_bucket=...' (or in
# dev.tfvars) so their remote-state reads resolve to this object.
bucket = "terraform-state-<YOUR_AWS_ACCOUNT_ID>"
key    = "dev/registry/terraform.tfstate"
region = "eu-north-1"

encrypt = true
# SSE-KMS CMK for state-at-rest encryption (omit for SSE-S3/AES256).
kms_key_id = "arn:aws:kms:eu-north-1:<YOUR_AWS_ACCOUNT_ID>:key/<STATE_CMK_KEY_ID>"

# Native S3 state locking (Terraform >= 1.10) — no DynamoDB lock table needed.
use_lockfile = true
